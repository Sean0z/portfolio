---
import "../../styles/global.css";
import { siteConfig } from "../../config";
---

<html lang="en">
  <head>
    <title>Sports| {siteConfig.name}</title>
  </head>

  <body>
    <main class="min-h-screen p-8 sm:p-12 md:p-16 lg:p-24">
      <a
        href={`${import.meta.env.BASE_URL}#projects`}
        class="text-gray-600 hover:text-gray-900"
      >
        &larr; Back to projects
      </a>

      <section class="mt-12">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-900">
          Sports
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-gray-600 leading-relaxed">
          This is a test page for the Sports project.
        </p>
      </section>
    </main>
  </body>
</html>